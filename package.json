{
  "version": "0.7.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/villander/ember-engines-router-service"
  },
  "scripts": {
    "build": "pnpm -F ember-engines-router-service build",
    "lint": "pnpm -r lint --if-present",
    "lint:fix": "pnpm -r lint:fix --if-present",
    "prepare": "pnpm build",
    "release": "release-it",
    "start": "concurrently 'pnpm:start:*' --restart-after 5000 --prefix-colors cyan,white,yellow",
    "start:addon": "pnpm -F ember-engines-router-service start",
    "start:test-app": "pnpm -F test-app start",
    "test": "pnpm -r test --if-present",
    "test:ember": "pnpm -F test-app test:ember"
  },
  "devDependencies": {
    "@release-it-plugins/lerna-changelog": "^7.0.0",
    "@release-it-plugins/workspaces": "^4.2.0",
    "release-it": "^17.5.0"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "release-it": {
    "hooks": {
      "before:init": "cp README.md LICENSE.md ember-engines-router-service/"
    },
    "plugins": {
      "@release-it-plugins/lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": false
      },
      "@release-it-plugins/workspaces": {
        "workspaces": [
          "ember-engines-router-service"
        ],
        "additionalManifests": {
          "dependencyUpdates": [
            "test-app/package.json"
          ],
          "versionUpdates": [
            "package.json",
            "test-app/package.json"
          ]
        }
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": true,
      "tokenRef": "GITHUB_AUTH"
    },
    "npm": false
  }
}
